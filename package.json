{
  "name": "traceroot",
  "version": "1.0.0",
  "private": true,
  "description": "AI engineering intelligence for any public GitHub repo.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "preflight": "npm run typecheck && npm run lint && npm run build",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset": "tsx scripts/reset-db.ts",
    "test:ai": "tsx scripts/test-ai.ts",
    "db:migrate-ai": "tsx scripts/migrate-ai.ts",
    "test:chat": "tsx scripts/test-chat.ts",
    "test": "tsx scripts/test-ai.ts && tsx scripts/test-chat.ts"
  },
  "dependencies": {
    "next": "15.5.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "drizzle-orm": "0.36.4",
    "better-sqlite3": "11.7.0",
    "iron-session": "8.0.4",
    "bcryptjs": "2.4.3",
    "zod": "3.24.1",
    "lucide-react": "0.460.0",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@types/better-sqlite3": "7.6.12",
    "@types/bcryptjs": "2.4.6",
    "autoprefixer": "10.4.20",
    "drizzle-kit": "0.30.1",
    "eslint": "9.17.0",
    "eslint-config-next": "15.5.3",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "tailwindcss": "3.4.15",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
}
