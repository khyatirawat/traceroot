# ──────────────────────────────────────────────────────────────
# TraceRoot environment variables
# Copy this file to .env.local and fill in what you need.
# ──────────────────────────────────────────────────────────────

# Session encryption secret — at least 32 characters.
# Generate one with: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# GitHub personal access token (optional but recommended).
# Without it, the GitHub API limits you to 60 requests/hour.
# With it, you get 5,000 requests/hour.
# Create one at: https://github.com/settings/tokens (classic, no scopes needed)
GITHUB_TOKEN=

# Database path (optional, defaults to ./data/traceroot.db)
# DATABASE_URL=file:./data/traceroot.db

# ─── AI providers (all optional) ───────────────────────────
# At least one enables AI suggestions + chat copilot.
# If none are set, the app works in heuristic-only mode.

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=
# AI_PROVIDER=openai

# Anthropic (https://console.anthropic.com/)
# ANTHROPIC_API_KEY=
# AI_PROVIDER=anthropic

# GitHub Models (https://github.com/settings/tokens — needs "Models" scope)
# AI_GITHUB_TOKEN=
# AI_PROVIDER=github-models
